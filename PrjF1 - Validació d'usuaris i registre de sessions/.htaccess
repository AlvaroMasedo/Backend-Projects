# Deshabilitar llistat de directoris
Options -Indexes

# Bloquejar arxius sensibles
<FilesMatch "\.(env|sql|config|htaccess)$">
    Deny from all
</FilesMatch>

# Deshabilitar PHP en uploads
<Directory "*/uploads/*">
    php_flag engine off
</Directory>

# Capçaleres de seguretat
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>
